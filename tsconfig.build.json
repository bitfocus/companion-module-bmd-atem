{
	"extends": "@companion-module/tools/tsconfig/node22/recommended.json",
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules/**", "src/**/*spec.ts", "src/**/__tests__/*", "src/**/__mocks__/*"],
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",
		"baseUrl": "./",
		"module": "node20",
		"moduleResolution": "node16"
	}
}
